#!/usr/bin/env bash
set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "${PROJECT_ROOT}" ]]; then
  echo "[pre-push][error] not inside git repository" >&2
  exit 1
fi

# shellcheck source=/dev/null
source "${PROJECT_ROOT}/scripts/agent_workflow_lib.sh"
aw_cd_repo_root

while read -r _local_ref _local_sha remote_ref _remote_sha; do
  [[ -z "${remote_ref}" ]] && continue
  case "${remote_ref}" in
    refs/heads/dev|refs/heads/main)
      aw_fail "push to protected branch is forbidden: ${remote_ref#refs/heads/}"
      ;;
  esac
done

bash "${AW_REPO_ROOT}/scripts/task_check.sh"
